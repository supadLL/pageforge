electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electronjs-binaries/
# 跳过 Electron 二进制自动下载（开发机常无法访问 GitHub Releases）
# 真正运行/打包时通过 npm config 或环境变量 ELECTRON_SKIP_BINARY_DOWNLOAD=0 开启，
# 并使用上面的国内镜像。
electron_skip_binary_download=1
audit=false
fund=false
