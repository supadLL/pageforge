{
  "name": "pageforge",
  "version": "0.1.0",
  "private": true,
  "description": "AI-driven visual page builder — schema-first Electron + Vue 3 desktop app.",
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:build": "npm run build && vitest run",
    "gen:examples": "node --experimental-strip-types scripts/gen-examples.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "pinia": "^2.2.2",
    "vue": "^3.4.38"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@vitejs/plugin-vue": "^5.1.2",
    "@vue/test-utils": "^2.4.6",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "electron": "^32.0.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^24.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vitest": "^2.0.5",
    "vue-tsc": "^2.0.29"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
